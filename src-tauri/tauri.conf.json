{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GitChef",
  "version": "0.25.0",
  "identifier": "com.gitchef.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "GitChef",
        "width": 1280,
        "height": 820,
        "minWidth": 940,
        "minHeight": 600,
        "decorations": false,
        "transparent": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data: https://*.gravatar.com https://avatars.githubusercontent.com https://github.com https://gitlab.com; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        },
        "background": "dmg/background.png"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdCNjE2QzEzMDA4RkNDMkEKUldRcXpJOEFFMnhoZTBsampjUTlkaTN4KzdweWY4THdtTGNkUFg4azU2TUMyQjM3TDlHYURrWi8K",
      "endpoints": [
        "https://REPLACE_WITH_R2_DEV_URL.r2.dev/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
