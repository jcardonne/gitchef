{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GitChef",
  "version": "0.4.1",
  "identifier": "com.gitchef.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "GitChef",
        "width": 1280,
        "height": 820,
        "minWidth": 940,
        "minHeight": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdCNjE2QzEzMDA4RkNDMkEKUldRcXpJOEFFMnhoZTBsampjUTlkaTN4KzdweWY4THdtTGNkUFg4azU2TUMyQjM3TDlHYURrWi8K",
      "endpoints": [
        "https://REPLACE_WITH_R2_DEV_URL.r2.dev/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
